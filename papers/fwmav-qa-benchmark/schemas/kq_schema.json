{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FWMAV-QA Knowledge Query Item",
  "description": "JSON Schema for category A (Knowledge Query) items in FWMAV-QA Benchmark",
  "type": "object",
  "required": [
    "id",
    "category",
    "type",
    "difficulty",
    "question",
    "gold_answer",
    "gold_entities",
    "expected_hops",
    "support_docs",
    "annotator",
    "annotation_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^kq_(g_)?[0-9]{3,4}$",
      "description": "Globally unique ID. Hand-written: kq_001~kq_9999. Template-generated: kq_g_001~kq_g_9999"
    },
    "category": {
      "type": "string",
      "enum": ["A1", "A2", "A3", "A4"]
    },
    "type": {
      "type": "string",
      "description": "Human-readable type label, e.g. '知识查询·单跳·定义'"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "question": {
      "type": "string",
      "minLength": 5,
      "description": "Natural language question (Chinese)"
    },
    "gold_answer": {
      "type": "string",
      "minLength": 10,
      "description": "Reference answer for EM/F1/Faithfulness scoring"
    },
    "gold_entities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "KG entity names that should appear in retrieval Top-k"
    },
    "gold_relations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional: relationship types invoked by the answer"
    },
    "gold_path": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional: expected reasoning path (for A3/A4 multi-hop)"
    },
    "expected_hops": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "tool_call_required": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hassanalian_weight",
          "shyy_scaling_law",
          "strouhal_check",
          "reynolds_check"
        ]
      },
      "description": "Tools the system should call, empty list if none"
    },
    "support_docs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "doi": { "type": "string" },
          "zotero_key": { "type": "string" },
          "snippet": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "string",
      "description": "Origin reference, e.g. 'KG node DelFly Nimble' or 'Pennycuick 1996'"
    },
    "annotator": { "type": "string" },
    "verified_by": { "type": "string" },
    "annotation_date": {
      "type": "string",
      "format": "date"
    }
  }
}
