{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FWMAV-QA Design Recommendation Item",
  "description": "JSON Schema for category B (Design Recommendation) items",
  "type": "object",
  "required": [
    "id",
    "category",
    "type",
    "difficulty",
    "question",
    "task_constraints",
    "gold_recommendations",
    "expected_recall_top10",
    "annotator",
    "annotation_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^dr_(g_)?[0-9]{3,4}$"
    },
    "category": {
      "type": "string",
      "enum": ["B1", "B2"]
    },
    "type": { "type": "string" },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "question": {
      "type": "string",
      "minLength": 10
    },
    "task_constraints": {
      "type": "object",
      "description": "Structured constraints in normalized units",
      "properties": {
        "endurance_min": { "type": "number" },
        "endurance_max": { "type": "number" },
        "endurance_unit": { "type": "string", "enum": ["s", "min"] },
        "weight_min_g": { "type": "number" },
        "weight_max_g": { "type": "number" },
        "wingspan_min_mm": { "type": "number" },
        "wingspan_max_mm": { "type": "number" },
        "frequency_min_hz": { "type": "number" },
        "frequency_max_hz": { "type": "number" },
        "speed_min_m_s": { "type": "number" },
        "can_hover": { "type": "boolean" },
        "mission_type": { "type": "string" },
        "biological_prototype": { "type": "string" }
      }
    },
    "gold_recommendations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["rank", "vehicle", "reasoning"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "vehicle": { "type": "string" },
          "match_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "reasoning": { "type": "string" }
        }
      }
    },
    "expected_recall_top10": {
      "type": "array",
      "minItems": 5,
      "maxItems": 10,
      "items": { "type": "string" },
      "description": "Up to 10 vehicles that recall stage should retrieve"
    },
    "tool_call_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "support_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "doi": { "type": "string" },
          "zotero_key": { "type": "string" }
        }
      }
    },
    "annotator": { "type": "string" },
    "verified_by": { "type": "string" },
    "annotation_date": {
      "type": "string",
      "format": "date"
    }
  }
}
