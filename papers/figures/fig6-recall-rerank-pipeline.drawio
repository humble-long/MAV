    <mxCell id="recall_subtitle" value="目标：覆盖广 + 召回率高 + 毫秒级" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#9673A6;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="240" y="135" width="320" height="18" as="geometry"/>
