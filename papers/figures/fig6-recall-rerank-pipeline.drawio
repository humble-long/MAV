    <mxCell id="r_step1" value="任务约束 → 查询矩阵 𝐐_raw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E3F0;strokeColor=#7E57C2;strokeWidth=1;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="270" y="170" width="260" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="r_step2" value="z-score 标准化 → 𝐐_norm&#10;最小二乘投影 → 𝐪 ∈ ℝ^R (R=12)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E3F0;strokeColor=#7E57C2;strokeWidth=1;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="270" y="225" width="260" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r_step3" value="混合相似度 sim = 0.6·cos_raw + 0.4·cos_embed&#10;对 39 架 FWMAV 排序" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E3F0;strokeColor=#7E57C2;strokeWidth=1;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="270" y="290" width="260" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r_step4" value="返回 Top-K 候选（默认 K=10）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6CCEA;strokeColor=#7E57C2;strokeWidth=1.5;fontSize=10;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="270" y="355" width="260" height="40" as="geometry"/>
    </mxCell>

