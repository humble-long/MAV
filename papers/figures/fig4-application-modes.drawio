    <mxCell id="left_q" value="&lt;b&gt;输入查询：&lt;/b&gt;&#10;&quot;鸽子和隼的扑频差异在哪？&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="100" y="160" width="420" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="left_t1" value="① search_organism(name=&quot;鸽子&quot;)&#10;→ 扑频 [3, 5] Hz, 体重 [200, 400] g" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2E5;strokeColor=#587A4A;strokeWidth=1;fontSize=10;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
