    <mxCell id="right_q" value="&lt;b&gt;输入查询：&lt;/b&gt;&#10;&quot;重量 30 g、续航 15 min、需悬停的微型扑翼机推荐&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
