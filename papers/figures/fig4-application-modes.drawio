    </mxCell>
    <mxCell id="left_t3" value="（可选）③ query_mimics_path(dominant_type=&quot;morphology&quot;)&#10;按形态相似度找以鸽子为原型的样机（兑现 4 类相似度通道）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2E5;strokeColor=#587A4A;strokeWidth=1;dashed=1;fontSize=10;verticalAlign=middle;align=left;spacingLeft=10;" vertex="1" parent="1">
