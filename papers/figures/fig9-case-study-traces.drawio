    <mxCell id="caseA_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F8FB;strokeColor=#3A6B8A;strokeWidth=1.5;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
